    <service name="IPForward" node="1">
      <templates>
        <template name="ipforward.sh"><![CDATA[#!/bin/sh

# 1. Bật card mạng không dây ảo (eth0)
ip link set up dev eth0

# 2. Tạo interface bat0 và gắn eth0 vào mạng mesh BATMAN
batctl if add eth0
ip link set up dev bat0

# 3. Lấy IP tự động được cấp trên eth0
IP_ADDR=$(ip -4 addr show eth0 | grep inet | awk '{print $2}')

# 4. Chuyển IP từ eth0 sang bat0 để định tuyến L3
if [ -n "$IP_ADDR" ]; then
    ip addr del $IP_ADDR dev eth0
    ip addr add $IP_ADDR dev bat0
fi]]></template>
