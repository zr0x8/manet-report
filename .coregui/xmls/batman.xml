  <service_configurations>
    <service name="IPForward" node="2">
      <templates>
        <template name="ipforward.sh"><![CDATA[#!/bin/sh

# 1. Bật card vật lý ảo
ip link set up dev eth0

# 2. Tạo interface bat0 và gắn eth0 vào mạng mesh BATMAN
batctl if add eth0
ip link set up dev bat0

# 3. Lấy IP tự động kèm Subnet (VD: 10.0.0.20/32)
IP_CIDR=$(ip -4 addr show eth0 | grep -w inet | awk '{print $2}')

if [ -n "$IP_CIDR" ]; then
    # Bóc lấy chỉ mỗi phần IP (VD: 10.0.0.20)
    IP_ONLY=$(echo $IP_CIDR | cut -d'/' -f1)
    
    # Xóa IP cũ có mask sai trên eth0
    ip addr del $IP_CIDR dev eth0
    
    # Gán IP đó sang bat0 với Subnet Mask đúng là /24
    ip addr add $IP_ONLY/24 dev bat0
fi]]></template>
      </templates>
    </service>
